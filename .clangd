CompileFlags:
  Add:
    - --target=i386-none-elf
    - -std=c11
    - -ffreestanding
    - -fno-builtin
    - -fno-stack-protector
    - -fno-pic
    - -nostdlib
    - -I/Users/hasircioglu/projects/mykernel/include
    - -I/Users/hasircioglu/projects/mykernel/src/drivers/mkdx
    - -I/Users/hasircioglu/projects/mykernel/src/drivers/display/bga
    - -I/Users/hasircioglu/projects/mykernel/src/drivers/display/virtio_gpu
  Remove:
    - -m32
    - -m64

Index:
  Background: Build
